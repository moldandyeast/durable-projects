{
  "name": "durable-projects",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:client": "node scripts/bundle-project-runtime.mjs",
    "predev": "npm run build:client",
    "dev": "wrangler dev --env dev",
    "deploy": "npm run build:client && wrangler deploy --env=\"\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "verify": "bash scripts/verify-repo-hygiene.sh"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "esbuild": "^0.24.2",
    "typescript": "^5.4.0",
    "vitest": "^4.1.6",
    "wrangler": "^4.92.0"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.7",
    "marked": "^12.0.0"
  }
}
